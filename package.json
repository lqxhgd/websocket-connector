{
  "name": "openclaw-websocket-connector",
  "version": "0.1.0",
  "description": "OpenClaw universal WebSocket plugin - connect any web app to OpenClaw via WebSocket",
  "main": "src/index.ts",
  "type": "module",
  "keywords": [
    "openclaw",
    "websocket",
    "plugin",
    "connector",
    "ai",
    "chat"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lqxhgd/websocket-connector.git"
  },
  "homepage": "https://github.com/lqxhgd/websocket-connector#readme",
  "bugs": {
    "url": "https://github.com/lqxhgd/websocket-connector/issues"
  },
  "author": "lqxhgd",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts"
  },
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "channel": {
      "id": "websocket-connector",
      "label": "WebSocket Connector",
      "order": 50
    },
    "install": {
      "npmSpec": "openclaw-websocket-connector"
    }
  },
  "dependencies": {
    "ws": "^8.18.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/ws": "^8.5.13",
    "@types/node": "^20.17.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.19.0"
  },
  "license": "MIT"
}
